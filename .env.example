# Copy to .env and fill in. Only DASHBOARD_PASSWORD and SESSION_SECRET are
# required to run; the rest have sensible defaults.

# Login password for the dashboard.
DASHBOARD_PASSWORD=change-me

# Signs the auth session cookie. REQUIRED in production — the app refuses to
# start without it (an unset secret would make the cookie forgeable). Generate:
#   openssl rand -hex 32
SESSION_SECRET=

# Optional. Enables headless/automation access: requests sending
#   Authorization: Bearer <API_KEY>
# are authenticated without the browser login. Leave unset to disable the token
# path entirely. Generate a long random value, e.g. openssl rand -hex 32
API_KEY=

# SQLite database location (Prisma + better-sqlite3).
DATABASE_URL=file:prisma/dev.db

# Where uploaded reader files (PDF/EPUB) are stored.
# UPLOADS_DIR=/data/uploads
